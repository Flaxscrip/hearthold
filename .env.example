# Hearthold environment — copy to .env (which is gitignored)

# Wallet passphrase for the local agent. Each agent process reads this to unlock its wallet.
HEARTHOLD_PASSPHRASE=

# Archon node (Drawbridge) URL — fronts the gatekeeper API, capabilities, and the DIDComm mount.
# Must be the Drawbridge URL (:4222), not the raw Gatekeeper (:4224).
HEARTHOLD_NODE_URL=http://flaxlap.local:4222

# Anchoring registry on the local node.
HEARTHOLD_REGISTRY=hyperswarm

# Root folder for per-agent wallets, vault, and index.
HEARTHOLD_DATA_ROOT=

# ── Witness (Companion) ──
# The Warden's did:cid — the address the Witness sends to over DIDComm. Required for `witness submit`.
HEARTHOLD_WARDEN_DID=
