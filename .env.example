# Hearthold environment — copy to .env (which is gitignored)

# Wallet passphrase for the local agent. Each agent process reads this to unlock its wallet.
HEARTHOLD_PASSPHRASE=

# Archon node (Drawbridge) URL — fronts the gatekeeper API, capabilities, and the DIDComm mount.
# Must be the Drawbridge URL (:4222), not the raw Gatekeeper (:4224).
HEARTHOLD_NODE_URL=http://flaxlap.local:4222

# Anchoring registry on the local node.
HEARTHOLD_REGISTRY=hyperswarm

# Root folder for per-agent wallets, vault, and index.
HEARTHOLD_DATA_ROOT=

# ── Emissary (Companion) ──
# The Warden's did:cid — the address the Emissary sends to over DIDComm. Required for `emissary submit`.
HEARTHOLD_WARDEN_DID=

# ── Warden classifier (local-only model) ──
# Local Ollama endpoint and model used to classify artefact sensitivity on-device.
HEARTHOLD_OLLAMA_URL=http://localhost:11434
HEARTHOLD_CLASSIFIER_MODEL=qwen3:8b
# Set to 'quarantine' to disable the model and treat everything as SEALED (fail-safe).
HEARTHOLD_CLASSIFIER=

# ── Docker sandbox (docker-compose.hearthold.yml) ──
# For the offline Docker sandbox you only need HEARTHOLD_PASSPHRASE set here — the
# compose file supplies NODE_URL=http://drawbridge:4222, REGISTRY=local, CLASSIFIER=
# quarantine, and DATA_ROOT itself. Copy this file to .env and set a sandbox value:
#   HEARTHOLD_PASSPHRASE=hearthold-sandbox-dev
# See deploy/sandbox/README.md.
