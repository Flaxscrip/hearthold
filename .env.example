# Hearthold environment — copy to .env (which is gitignored)

# Wallet passphrase for the local agent. Each agent process reads this to unlock its wallet.
HEARTHOLD_PASSPHRASE=

# Archon Gatekeeper used to resolve/register did:cid identities.
HEARTHOLD_GATEKEEPER_URL=http://flaxlap.local:4224

# Anchoring registry on the local node.
HEARTHOLD_REGISTRY=hyperswarm

# Root folder for per-agent wallets, vault, and index.
HEARTHOLD_DATA_ROOT=

# ── Warden (home Keeper) ──
# Address to bind the HTTP service to. Default 127.0.0.1; set to the Warden's Tailscale IP
# (or 0.0.0.0) to accept the Witness over your private network.
HEARTHOLD_WARDEN_BIND=127.0.0.1
HEARTHOLD_WARDEN_PORT=8787

# ── Witness (Companion) ──
# Base URL of the Warden over your private (Tailscale) network. Required for `witness submit`.
HEARTHOLD_WARDEN_URL=http://127.0.0.1:8787
