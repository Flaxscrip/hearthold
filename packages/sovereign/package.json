{
  "name": "@hearthold/sovereign",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hearthold Sovereign — the principal identity (Signet precursor): accept third-party credentials, co-sign approvals.",
  "bin": {
    "sovereign": "./dist/index.js"
  },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./handler": { "types": "./dist/handler.d.ts", "import": "./dist/handler.js" },
    "./signet": { "types": "./dist/signet.d.ts", "import": "./dist/signet.js" }
  },
  "scripts": {
    "build": "tsc --build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hearthold/control-types": "0.1.0",
    "@hearthold/core": "0.1.0"
  }
}
