{
  "name": "@hearthold/warden",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hearthold Warden — home Keeper service: vault, local-AI classification, index, prover.",
  "bin": {
    "warden": "./dist/index.js"
  },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./service": { "types": "./dist/service.d.ts", "import": "./dist/service.js" },
    "./handler": { "types": "./dist/handler.d.ts", "import": "./dist/handler.js" },
    "./delegations": { "types": "./dist/delegations.d.ts", "import": "./dist/delegations.js" },
    "./store": { "types": "./dist/store.d.ts", "import": "./dist/store.js" },
    "./evidence": { "types": "./dist/evidence.d.ts", "import": "./dist/evidence.js" },
    "./recall": { "types": "./dist/recall.d.ts", "import": "./dist/recall.js" },
    "./index-store": { "types": "./dist/index-store.d.ts", "import": "./dist/index-store.js" },
    "./kb": { "types": "./dist/kb.d.ts", "import": "./dist/kb.js" },
    "./kb-config": { "types": "./dist/kb-config.d.ts", "import": "./dist/kb-config.js" },
    "./kb-seed": { "types": "./dist/kb-seed.d.ts", "import": "./dist/kb-seed.js" },
    "./face": { "types": "./dist/face.d.ts", "import": "./dist/face.js" },
    "./triage": { "types": "./dist/triage.d.ts", "import": "./dist/triage.js" },
    "./marks": { "types": "./dist/marks.d.ts", "import": "./dist/marks.js" },
    "./ruleset-store": { "types": "./dist/ruleset-store.d.ts", "import": "./dist/ruleset-store.js" },
    "./classifier": { "types": "./dist/classifier.d.ts", "import": "./dist/classifier.js" }
  },
  "scripts": {
    "build": "tsc --build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hearthold/control-types": "0.1.0",
    "@hearthold/core": "0.1.0"
  }
}
